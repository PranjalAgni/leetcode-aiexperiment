# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://algoarena:algoarena_dev@localhost:5432/algoarena

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT Keys (generate with: node -e "const {generateKeyPairSync}=require('crypto');const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048});console.log(privateKey.export({type:'pkcs8',format:'pem'}));console.log(publicKey.export({type:'spki',format:'pem'}))")
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=change-this-to-a-random-secret-in-production

# ─── OAuth ────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Auth.js (Next.js) ────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-this-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# ─── Service URLs (for local dev, services run on these ports) ────────────────
API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

AUTH_SERVICE_URL=http://localhost:4001
USER_SERVICE_URL=http://localhost:4002
PROBLEM_SERVICE_URL=http://localhost:4003
SUBMISSION_SERVICE_URL=http://localhost:4004
CONTEST_SERVICE_URL=http://localhost:4006
NOTIFICATION_SERVICE_URL=http://localhost:4007

# ─── Internal API Key (judge ↔ problem service) ───────────────────────────────
INTERNAL_API_KEY=dev-internal-key-change-in-production

# ─── Email (for password reset, notifications) ────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@algoarena.dev

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Judge service ────────────────────────────────────────────────────────────
ISOLATE_BIN=/usr/local/bin/isolate
SANDBOX_DIR=/tmp/judge
NUM_WORKERS=0  # 0 = auto (NumCPU * 2)

# ─── Service metadata ─────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000
